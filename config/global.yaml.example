# Code AST Graph - 全局配置文件示例
# 复制此文件为 config/global.yaml 并根据需要修改

# 应用配置
app:
  name: "Code AST Graph"
  version: "1.0.0"
  debug: false
  log_level: "INFO"  # DEBUG, INFO, WARNING, ERROR

# 存储配置
storage:
  backend: "neo4j"  # neo4j, memgraph, arangodb
  
  neo4j:
    uri: "bolt://localhost:7687"
    user: "neo4j"
    password: "password"  # 建议使用环境变量: ${NEO4J_PASSWORD}
    max_connection_pool_size: 50
    connection_timeout: 30
  
  memgraph:
    uri: "bolt://localhost:7687"
    user: "memgraph"
    password: "password"
  
  arangodb:
    url: "http://localhost:8529"
    database: "code_ast_graph"
    username: "root"
    password: "password"

# UI 配置
ui:
  host: "0.0.0.0"
  port: 7860
  share: false
  theme: "dark"

# 路径配置
paths:
  git_repos: "./git-repos"
  cache_dir: "./.cache"
  metadata_dir: "./.metadata"
