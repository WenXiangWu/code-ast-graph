# ==================== 服务端口配置 ====================
# 后端 API 服务端口
BACKEND_PORT=8000
# 前端开发服务器端口
FRONTEND_PORT=3000

# ==================== Neo4j 配置 ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Python AST 配置
PYTHON_AST_ENABLED=true
PYTHON_AST_EXCLUDE_DIRS=target,build,.git,node_modules,out,bin,test
PYTHON_AST_EXCLUDE_PATTERNS=*Test.java,*Tests.java,*Mock.java
PYTHON_AST_EXCLUDE_ANNOTATIONS=
PYTHON_AST_EXCLUDE_ANNOTATION_PATTERNS=

# jQAssistant 配置（可选）
JQASSISTANT_ENABLED=false
JQASSISTANT_NEO4J_URI=bolt://localhost:7687
JQASSISTANT_NEO4J_USER=neo4j
JQASSISTANT_NEO4J_PASSWORD=password
JQASSISTANT_VERSION=2.8.0
JQASSISTANT_SCAN_TIMEOUT=3600
JQASSISTANT_USE_DOCKER=false
