# ==================== Git 鉴权配置 ====================
# Git 仓库克隆时的鉴权配置（用于私有仓库）
# 支持三种鉴权方式：Basic Auth、Token、SSH

# 方式一：Basic Auth（用户名/密码）
# GIT_USERNAME=your_username
# GIT_PASSWORD=your_password

# 方式二：Token（Personal Access Token 或 OAuth Token，推荐）
 GIT_TOKEN=你的token
# 或
# GIT_ACCESS_TOKEN=your_oauth_token

# 方式三：SSH 密钥（用于 SSH URL，如 git@git.yupaopao.com:xxx.git）
# GIT_SSH_KEY_PATH=~/.ssh/id_rsa
# GIT_SSH_KEY_PASSWORD=  # SSH 密钥密码（如果密钥有密码保护，建议使用 ssh-agent）

# 注意：
# 1. 系统会自动检测鉴权方式（优先级：SSH > Token > Basic Auth）
# 2. 如果使用 SSH 方式，确保 SSH 密钥已配置好权限（chmod 600）
# 3. 如果 SSH 密钥有密码，建议预先运行: ssh-add ~/.ssh/id_rsa
# 4. Token 方式最安全，推荐使用

# ==================== Kafka 配置 ====================
# GitLab Merge 事件监听配置（用于增量索引触发）
# Kafka bootstrap servers 地址
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# GitLab 监听配置
GITLAB_TOPIC=gitlab-push-info
GITLAB_CONSUMER_GROUP=code-index
# 监听的目标分支（只处理合并到该分支的 MR 事件）
GITLAB_PROD_BRANCH=test

# 可选：允许处理的服务列表（JSON 数组格式，为空则处理所有）
# CODE_ENTRY_ALLOWED_SERVICES=["service1","service2"]

# ==================== 服务端口配置 ====================
BACKEND_PORT=18001
FRONTEND_PORT=3001
MCP_PORT=18086

# ============================================
# Python AST 知识图谱配置（纯 Python，无需 Java）
# ============================================

# === 功能开关 ===
PYTHON_AST_ENABLED=true
# 是否生成扫描报告（按 project -> module -> package -> class 分类）
GENERATE_SCAN_REPORT=true

# === Neo4j 连接配置 ===
NEO4J_URI=bolt://localhost:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=jqassistant123

